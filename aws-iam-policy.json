{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowS3ObjectOperations",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": "arn:aws:s3:::course-contents-creatorhub/*"
        },
        {
            "Sid": "AllowS3BucketList",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": "arn:aws:s3:::course-contents-creatorhub"
        }
    ]
}